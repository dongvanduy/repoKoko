<!DOCTYPE html>
<html lang="<%= getLocale() %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { colors: { bgBase: 'rgba(248, 244, 230, 1)', main: '#544A47', accent: '#BA2636', sub1: '#8D837F' } } } }
    </script>
</head>
<body class="bg-bgBase text-main font-sans pb-32">

    <header class="px-8 flex justify-center bg-white shadow-sm sticky top-0 z-50">
        <a href="/"><img src="/img/common/logo.svg" alt="Kokoro Kimono Rental Kyoto logo" class="h-14"></a>
    </header>

    <main class="max-w-[1000px] mx-auto px-5">
        <div class="flex justify-between items-center text-sm border-b mb-4">
            <span class="font-bold text-accent"><%= __('booking.nav.step1') %></span>
            <span class="text-gray-400"><%= __('booking.nav.step2') %></span>
            <span class="text-gray-400"><%= __('booking.nav.step3') %></span>
        </div>

        <h1 class="text-2xl font-bold text-center mb-4"><%= __('booking.step1.title') %></h1>

        <form action="/booking-step2" method="POST" id="bookingForm">
            
            <div class="grid gap-6">
                <% plans.forEach(plan => { %>
                    <div class="bg-white shadow-sm rounded-2xl overflow-hidden md:flex border border-transparent transition hover:shadow-lg group plan-card" 
                         data-price="<%= plan.price %>">
                        
                        <div class="md:w-[200px] h-[200px] md:h-auto flex-shrink-0 rounded-lg overflow-hidden relative">
                            <img src="<%= plan.image || plan.img %>" alt="kimono rental Kyoto booking plan - <%= getLocalizedText(plan.title) %>" class="w-full h-full object-cover" loading="lazy" decoding="async">
                            <% if(plan.tag) { %> <span class="absolute top-2 left-2 bg-yellow-500 text-white text-[10px] font-bold px-2 py-1 rounded"><%= plan.tag %></span> <% } %>
                        </div>

                        <div class="mt-4 md:mt-0 md:ml-6 flex flex-col justify-center w-full">
                            <div class="flex justify-between items-start">
                                <h3 class="text-xl font-bold text-main pr-4"><%= getLocalizedText(plan.title) %></h3>
                                <div class="text-right whitespace-nowrap">
                                    <span class="text-accent text-2xl font-bold"><%= formatPrice(plan.price) %></span>
                                    <span class="text-xs text-main block mt-1"><%= __('booking.common.per_person') %></span>
                                </div>
                            </div>
                            <p class="text-sm text-sub1 line-clamp-2 mt-2 mb-4"><%= getLocalizedText(plan.desc) %></p>
                            <div class="mt-auto bg-gray-50 p-3 rounded-lg flex items-center justify-between">
                                <span class="font-bold text-sm"><%= __('booking.step1.quantity_label') %></span>
                                <div class="relative w-32">
                                    <select name="plan_<%= plan.id %>" class="quantity-select w-full border border-gray-300 p-2 rounded-lg font-bold text-center focus:border-accent outline-none">
                                        <option value="0">0</option>
                                        <option value="1"><%= __n('booking.common.guest_count', 1) %></option>
                                        <option value="2"><%= __n('booking.common.guest_count', 2) %></option>
                                        <option value="3"><%= __n('booking.common.guest_count', 3) %></option>
                                        <option value="4"><%= __n('booking.common.guest_count', 4) %></option>
                                        <option value="5"><%= __n('booking.common.guest_count', 5) %></option>
                                        <option value="10"><%= __('booking.common.guest_count_10_plus') %></option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="fixed bottom-0 left-0 w-full bg-white border-t p-4 shadow-[0_-4px_10px_rgba(0,0,0,0.1)] z-50">
                <div class="max-w-[1000px] mx-auto flex justify-between items-center">
                    <div>
                        <div class="text-sm text-gray-500"><%= __('booking.step1.selected_label') %> <span id="totalQty" class="font-bold text-black">0</span></div>
                        <div class="text-2xl font-bold text-accent">¥<span id="totalPrice">0</span></div>
                    </div>
                    <button type="submit" id="submitBtn" disabled class="bg-gray-400 text-white font-bold py-3 px-8 rounded-full shadow-lg transition transform hover:-translate-y-1 disabled:opacity-50 disabled:cursor-not-allowed">
                        <%= __('booking.step1.submit') %>
                    </button>
                </div>
            </div>
        </form>
    </main>

    <script>
        const selects = document.querySelectorAll('.quantity-select');
        const totalQtyEl = document.getElementById('totalQty');
        const totalPriceEl = document.getElementById('totalPrice');
        const submitBtn = document.getElementById('submitBtn');

        function updateTotal() {
            let totalQ = 0;
            let totalP = 0;

            selects.forEach(select => {
                const qty = parseInt(select.value);
                if (qty > 0) {
                    const price = parseInt(select.closest('.plan-card').dataset.price);
                    totalQ += qty;
                    totalP += qty * price;
                    
                    // Highlight card đã chọn
                    select.closest('.plan-card').classList.add('border-accent', 'ring-1', 'ring-accent');
                } else {
                    select.closest('.plan-card').classList.remove('border-accent', 'ring-1', 'ring-accent');
                }
            });

            // Cập nhật giao diện
            totalQtyEl.innerText = totalQ;
            totalPriceEl.innerText = totalP.toLocaleString();

            // Bật/Tắt nút Submit
            if (totalQ > 0) {
                submitBtn.disabled = false;
                submitBtn.classList.remove('bg-gray-400');
                submitBtn.classList.add('bg-gradient-to-r', 'from-pink-500', 'to-[#BA2636]');
            } else {
                submitBtn.disabled = true;
                submitBtn.classList.add('bg-gray-400');
                submitBtn.classList.remove('bg-gradient-to-r', 'from-pink-500', 'to-[#BA2636]');
            }
        }

        // Lắng nghe sự kiện thay đổi
        selects.forEach(select => {
            select.addEventListener('change', updateTotal);
        });
    </script>
</body>
</html>
