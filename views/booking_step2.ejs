<!DOCTYPE html>
<html lang="<%= getLocale() %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { colors: { bgBase: 'rgba(248, 244, 230, 1)', main: '#544A47', accent: '#BA2636', sub1: '#8D837F' } } } }
    </script>
    <style>
        .time-radio:checked + div { background: linear-gradient(to bottom right, #BA2636, #C53D43); color: white; border-color: #BA2636; }
        .time-radio:disabled + div { opacity: 0.3; cursor: not-allowed; background-color: #f3f3f3; }
    </style>
</head>
<body class="bg-bgBase text-main font-sans pb-40">

    <header class="px-8 flex justify-center bg-white shadow-sm sticky top-0 z-50">
        <a href="/"><img src="/img/common/logo.svg" alt="Kokoro Kimono Rental Kyoto logo" class="h-14"></a>
    </header>

    <main class="max-w-[1260px] mx-auto px-5 md:px-8 mt-4">
        
        <div class="hidden lg:block mb-6">
            <ol class="flex gap-4">
                <li class="text-sub1"><%= __('booking.nav.step1') %></li>
                <li class="font-bold text-accent relative pl-4">
                    <span class="absolute top-2 left-0 w-2 h-2 bg-accent rounded-full"></span>
                    <%= __('booking.nav.step2') %>
                </li>
                <li class="text-sub1"><%= __('booking.nav.step3') %></li>
                <li class="text-sub1"><%= __('booking.nav.step4') %></li>
            </ol>
        </div>

        <form action="/booking-step3" method="POST" id="step2Form"> <input type="hidden" name="selectedPlans" value="<%= JSON.stringify(selectedPlans) %>">
            <input type="hidden" name="shopId" value="<%= shop.id || 1 %>">
            <input type="hidden" name="totalQuantity" value="<%= totalQuantity %>">

            <div class="grid lg:grid-cols-[1fr_350px] gap-8">
                
                <div>
                    <h2 class="text-xl font-bold border-b border-dashed border-sub1 pb-3 mb-6">
                        <%= __n('booking.step2.title', totalQuantity, totalQuantity) %>
                    </h2>

                    <div class="bg-white p-6 rounded-3xl shadow-sm mb-6">
                        <label class="block font-bold mb-2 text-lg"><%= __('booking.step2.date_label') %></label>
                        <input type="date" name="date" required 
                               class="w-full border border-gray-300 p-4 rounded-xl text-lg focus:border-accent focus:ring-1 focus:ring-accent outline-none">
                    </div>

                    <div class="bg-white p-6 rounded-3xl shadow-sm">
                        <h3 class="font-bold"><%= __('booking.step2.timeslot_label') %></h3>
                            <div id="slots-container" class="grid grid-cols-2 md:grid-cols-4 gap-3">
                                <div class="col-span-full text-center py-4 text-sub1"><%= __('booking.step2.loading_slots') %></div>
                            </div>
                    </div>
                </div>

                <div class="hidden lg:block">
                    <div class="bg-white rounded-xl p-6 shadow-lg sticky top-24 border border-gray-100">
                        <h3 class="font-bold text-xl border-b pb-2"><%= __('booking.step2.selected_plans') %></h3>
                        
                        <div class="space-y-4">
                            <% selectedPlans.forEach(p => { %>
                                <div class="flex gap-3">
                                    <img src="<%= p.image %>" alt="selected kimono rental Kyoto plan" class="w-12 h-12 rounded object-cover" loading="lazy" decoding="async">
                                    <div class="flex-1">
                                        <p class="font-bold text-sm text-main"><%= p.title %></p>
                                        <div class="flex justify-between text-xs text-sub1 mt-1">
                                            <span>x <%= __n('booking.common.guest_count', p.qty, p.qty) %></span>
                                            <span class="text-accent font-bold">¥<%= p.subTotal.toLocaleString() %></span>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <div class="border-t pt-4 mt-4 flex justify-between items-end">
                            <span class="font-bold text-main"><%= __n('booking.step2.total_label', totalQuantity, totalQuantity) %></span>
                            <span class="text-2xl font-bold text-accent">¥<%= totalPrice.toLocaleString() %></span>
                        </div>
                    </div>
                </div>

            </div>

            <div class="fixed bottom-0 left-0 w-full bg-white border-t p-3 shadow-[0_-4px_10px_rgba(0,0,0,0.1)] z-50">
                <div class="max-w-[1000px] mx-auto grid grid-cols-2 gap-4 md:flex md:justify-between md:items-center">
                    <div class="hidden md:block">
                        <span class="text-gray-500"><%= __('booking.common.total') %></span>
                        <span class="text-2xl font-bold text-accent ml-2">¥<%= totalPrice.toLocaleString() %></span>
                    </div>
                    
                    <a href="/booking-step1" class="border border-sub1 text-main font-bold py-3 rounded-full text-center hover:bg-gray-100 transition">
                        <%= __('booking.common.back') %>
                    </a>
                    
                    <button type="submit" class="bg-gradient-to-r from-pink-500 to-[#BA2636] text-white font-bold py-3 rounded-full shadow-lg hover:shadow-xl hover:-translate-y-1 transition">
                        <%= __('booking.step2.next_cta') %>
                    </button>
                </div>
            </div>

        </form>
    </main>

    <script>
    const dateInput = document.querySelector('input[name="date"]');
    const slotsContainer = document.getElementById('slots-container');
    const shopId = document.querySelector('input[name="shopId"]').value;
    const totalQty = document.querySelector('input[name="totalQuantity"]').value;
    const slotMessages = {
        loading: "<%= __('booking.step2.loading_slots') %>",
        checking: "<%= __('booking.step2.checking_availability') %>",
        full: "<%= __('booking.step2.time_full') %>",
        remainingTemplate: "<%= __('booking.step2.remaining_slots') %>",
        loadError: "<%= __('booking.step2.load_error') %>"
    };

    // 1. Cấu hình ngày mặc định (như cũ)
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    dateInput.valueAsDate = tomorrow;
    dateInput.min = new Date().toISOString().split("T")[0];

    // 2. Hàm gọi API và vẽ lại danh sách giờ
    async function updateSlots() {
        const selectedDate = dateInput.value;
        slotsContainer.innerHTML = `<div class="col-span-full text-center py-4">${slotMessages.checking}</div>`;

        try {
            const response = await fetch(`/api/available-slots?date=${selectedDate}&shopId=${shopId}&totalQuantity=${totalQty}`);
            const slots = await response.json();

            slotsContainer.innerHTML = ''; // Xóa thông báo loading

            slots.forEach((slot, index) => {
                const label = document.createElement('label');
                label.className = 'cursor-pointer relative';
                const remainingLabel = slotMessages.remainingTemplate.replace(/%\{count\}|%\((?:count)\)/g, slot.remaining);
                
                label.innerHTML = `
                    <input type="radio" name="time" value="${slot.time}" class="time-radio hidden" required ${slot.isFull ? 'disabled' : ''}>
                    <div class="border border-sub1 rounded-lg py-3 text-center transition hover:border-accent hover:text-accent">
                        <div class="text-lg font-bold">${slot.time}</div>
                        <div class="text-[10px] mt-1 ${slot.isFull ? 'text-red-500' : 'text-green-600'}">
                            ${slot.isFull ? slotMessages.full : remainingLabel}
                        </div>
                    </div>
                `;
                slotsContainer.appendChild(label);
            });
        } catch (error) {
            slotsContainer.innerHTML = `<div class="col-span-full text-red-500">${slotMessages.loadError}</div>`;
        }
    }

    // 3. Lắng nghe sự kiện đổi ngày
    dateInput.addEventListener('change', updateSlots);

    // 4. Chạy lần đầu khi trang vừa load
    updateSlots();
</script>
</body>
</html>
