    <script>
    document.addEventListener('DOMContentLoaded', () => {
        let lastScrollTop = 0;
        const header = document.getElementById('main-header');
        const nav = document.getElementById('quick-nav');
        const placeholder = document.getElementById('quick-nav-placeholder');
        
        // Vị trí ban đầu của thanh Nav (để biết khi nào cần dính)
        const navOffsetTop = nav.offsetTop; 
        const navHeight = nav.offsetHeight;

        window.addEventListener('scroll', () => {
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            
            // --- 1. XỬ LÝ HEADER (Ẩn/Hiện thông minh) ---
            if (scrollTop > lastScrollTop && scrollTop > 100) {
                // Đang kéo xuống & đã cuộn qua 100px -> Ẩn Header
                header.classList.add('-translate-y-full');
            } else {
                // Đang kéo lên -> Hiện Header
                header.classList.remove('-translate-y-full');
            }

            // --- 2. XỬ LÝ QUICK NAV (Dính dưới đáy) ---
            
            // Nếu cuộn qua vị trí ban đầu của Nav -> Biến nó thành Fixed ở đáy
            if (scrollTop > navOffsetTop + 100) {
                // Kích hoạt chế độ Sticky Bottom
                nav.classList.add('fixed', 'bottom-0', 'left-0', 'border-t', 'shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]');
                nav.classList.remove('border-b'); // Bỏ border dưới
                
                // Giữ chỗ để layout không bị giật (Jump)
                placeholder.style.height = `${navHeight}px`;
                
                // Ẩn thanh Sticky Footer cũ (nếu có) để tránh chồng chéo
                const oldStickyFooter = document.querySelector('.fixed.bottom-0.z-50.md\\:hidden');
                if(oldStickyFooter) oldStickyFooter.style.display = 'none';

            } else {
                // Trả về vị trí cũ (Dưới Banner)
                nav.classList.remove('fixed', 'bottom-0', 'left-0', 'border-t', 'shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]');
                nav.classList.add('border-b'); // Trả lại border dưới
                
                // Xóa giữ chỗ
                placeholder.style.height = '0';

                // Hiện lại Sticky Footer cũ (nếu có)
                const oldStickyFooter = document.querySelector('.fixed.bottom-0.z-50.md\\:hidden');
                if(oldStickyFooter) oldStickyFooter.style.display = 'flex';
            }

            lastScrollTop = scrollTop;
        });
    });
</script>
