                        <span class="text-white/20">|</span>
                        
                        <a href="/change-lang/jp" class="flex items-center gap-1 <%= getLocale() === 'jp' ? activeClass : normalClass %>">
                            <img src="https://flagcdn.com/w20/jp.png" class="w-4 h-auto shadow-sm" alt="JP"> JP
                        </a>
                        <span class="text-white/20">|</span>

                        <a href="/change-lang/zh" class="flex items-center gap-1 <%= getLocale() === 'zh' ? activeClass : normalClass %>">
                            <img src="https://flagcdn.com/w20/cn.png" class="w-4 h-auto shadow-sm" alt="ZH"> ZH
