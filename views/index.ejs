            </a>

            <a href="#flow" class="nav-item group flex-1 min-w-[80px] flex flex-col md:flex-row items-center justify-center gap-1 md:gap-2 p-2 rounded-lg hover:bg-red-50 transition cursor-pointer text-center">
                <span class="text-xl">🔄</span>
                <span class="text-xs md:text-sm font-bold text-gray-600 group-hover:text-accent"><%= __('quick_nav.flow') %></span>
            </a>

            <a href="#faq" class="nav-item group flex-1 min-w-[80px] flex flex-col md:flex-row items-center justify-center gap-1 md:gap-2 p-2 rounded-lg hover:bg-red-50 transition cursor-pointer text-center">
                <span class="text-xl">❓</span>
                <span class="text-xs md:text-sm font-bold text-gray-600 group-hover:text-accent"><%= __('quick_nav.faq') %></span>
            </a>

            <a href="/blog" class="nav-item group flex-1 min-w-[80px] flex flex-col md:flex-row items-center justify-center gap-1 md:gap-2 p-2 rounded-lg hover:bg-red-50 transition cursor-pointer text-center">
                <span class="text-xl"><%= seoText.navBlog %></span>
                <span class="text-xs md:text-sm font-bold text-gray-600 group-hover:text-accent"><%= seoText.navBlog %></span>
            </a>
        </div>
    </div>
</div>


        <section class="py-16 px-5 bg-white border-b border-gray-100">
            <div class="max-w-6xl mx-auto grid gap-8 md:grid-cols-[1.2fr_0.8fr] items-center">
                <div>
                    <span class="text-accent font-bold text-sm tracking-widest uppercase mb-2 block"><%= seoText.landingHeroEyebrow %></span>
                    <h2 class="text-3xl md:text-4xl font-serif font-bold text-main"><%= seoText.navRental %></h2>
                    <p class="mt-5 text-gray-700 leading-relaxed text-lg">
                        <%= seoText.landingHeroDescription %>
                    </p>
                </div>
                <div class="flex flex-col sm:flex-row md:flex-col gap-3">
                    <a href="/kimono-rental-kyoto" class="rounded-full bg-accent px-7 py-3 text-center font-bold text-white shadow-md hover:bg-red-700 transition"><%= seoText.viewRentalGuide %></a>
                    <a href="/blog" class="rounded-full border border-main px-7 py-3 text-center font-bold text-main hover:bg-main hover:text-white transition"><%= seoText.blogListingTitle %></a>
                </div>
            </div>
        </section>

        <section id="plans" class="py-20 px-5">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-16">
                    <span class="text-accent font-bold text-sm tracking-widest uppercase mb-2 block"><%= __('sections.plans.subtitle') %></span>
                    <h2 class="text-3xl md:text-4xl font-serif font-bold text-main"><%= __('sections.plans.title') %></h2>
                    <div class="w-20 h-1 bg-gold mx-auto mt-6"></div>
                </div>

                <div class="grid md:grid-cols-3 gap-10">
                    <% plans.forEach(plan => { %>
                        <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition duration-300 transform hover:-translate-y-1">
                            <div class="h-64 overflow-hidden relative group">
                                <img src="<%= plan.image || plan.img %>" alt="kimono rental Kyoto plan - <%= getLocalizedText(plan.title) %>" class="w-full h-full object-cover transition duration-500 group-hover:scale-110" loading="lazy" decoding="async">
                                <div class="absolute top-0 right-0 bg-accent text-white px-3 py-1 rounded-bl-lg font-bold tracking-wider shadow-sm">
                                    <%= formatPrice(plan.price) %>
                                </div>
                            </div>
                            <div class="p-6">
                                <h3 class="text-xl font-bold mb-2 text-gray-800"><%= getLocalizedText(plan.title) %></h3>
                                <p class="text-gray-600 mb-4 line-clamp-2 min-h-[3rem]">
                                    <%= getLocalizedText(plan.desc) %>
                                </p>
                                
                                <ul class="mb-6 space-y-2">
                                    <% (plan.features || []).slice(0, 3).forEach(feature => { %>
                                        <li class="flex items-center text-sm text-gray-500">
                                            <span class="text-accent mr-2">✓</span> <%= feature %>
                                        </li>
                                    <% }) %>
                                </ul>
                                <a href="/plan/<%= plan.id || plan._id %>" class="block w-full text-center bg-gray-800 text-white py-3 rounded-lg hover:bg-accent transition duration-300 font-bold">
                                    <%= __('home.plans.view_detail') %> </a>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </section>

