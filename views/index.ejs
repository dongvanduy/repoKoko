        <section id="flow" class="py-16 md:py-24 bg-[#fdfbf7]">
        <div class="max-w-7xl mx-auto px-5">
            <div class="text-center mb-16">
                <span class="text-accent font-bold text-sm tracking-widest uppercase mb-2 block"><%= __('home.flow.subtitle') %></span>
                <h2 class="text-3xl md:text-4xl font-serif font-bold text-main"><%= __('home.flow.title') %></h2>
                <div class="w-20 h-1 bg-gold mx-auto mt-6"></div>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 relative hover:-translate-y-2 transition duration-300">
                    <div class="absolute -top-5 -left-5 w-12 h-12 bg-accent text-white rounded-full flex items-center justify-center font-bold text-xl shadow-lg">1</div>
                    <div class="h-16 w-16 bg-red-50 rounded-full flex items-center justify-center mb-4 mx-auto text-3xl">📅</div>
                    <h3 class="text-xl font-bold text-center mb-3"><%= __('home.flow.step1_title') %></h3>
                    <p class="text-gray-500 text-sm text-center leading-relaxed"><%= __('home.flow.step1_desc') %></p>
                </div>

                <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 relative hover:-translate-y-2 transition duration-300">
                    <div class="absolute -top-5 -left-5 w-12 h-12 bg-accent text-white rounded-full flex items-center justify-center font-bold text-xl shadow-lg">2</div>
                    <div class="h-16 w-16 bg-red-50 rounded-full flex items-center justify-center mb-4 mx-auto text-3xl">👘</div>
                    <h3 class="text-xl font-bold text-center mb-3"><%= __('home.flow.step2_title') %></h3>
                    <p class="text-gray-500 text-sm text-center leading-relaxed"><%= __('home.flow.step2_desc') %></p>
