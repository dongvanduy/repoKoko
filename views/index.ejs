            </a>
            
            <a href="#gallery" class="nav-item group flex-1 min-w-[80px] flex flex-col md:flex-row items-center justify-center gap-1 md:gap-2 p-2 rounded-lg hover:bg-red-50 transition cursor-pointer text-center">
                <span class="text-xl">📸</span>
