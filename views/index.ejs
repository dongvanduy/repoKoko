    </header>

    <main>
        <div class="relative w-full h-screen md:h-[100dvh]">
        
        <div class="swiper mySwiper w-full h-full">
            <div class="swiper-wrapper">
                <% if (typeof heroImages !== 'undefined' && heroImages && heroImages.length > 0) { %>
                    
                    <% heroImages.forEach(img => { %>
                        <div class="swiper-slide relative">
                            <img src="<%= img %>" alt="kimono rental Kyoto near Kiyomizu Temple at Kokoro Kimono" class="w-full h-full object-cover" fetchpriority="high" decoding="async">
                            <div class="absolute inset-0 bg-black/40"></div>
                        </div>
                    <% }) %>

                <% } else { %>
                    <div class="swiper-slide relative">
                        <img src="https://static.kyotokimonorental.com/app/img/top/hero/autumn/vi/sp/hero01.webp" 
                             alt="kimono rental Kyoto near Kiyomizu Temple at Kokoro Kimono"
                             class="w-full h-full object-cover" fetchpriority="high" decoding="async">
                        <div class="absolute inset-0 bg-black/40"></div>
                    </div>
                <% } %>
            </div>
            <div class="swiper-pagination"></div>
        </div>

        <div class="absolute inset-0 z-20 flex items-center justify-center pointer-events-none">
            <div class="text-center text-white p-5 animate-fade-in-up pointer-events-auto">
                <span class="block text-gold font-serif text-base md:text-lg mb-4 italic tracking-wider drop-shadow-md"><%= __('hero.tagline') %></span>
                
                <h1 class="text-3xl md:text-5xl font-bold font-serif leading-tight mb-6 drop-shadow-lg max-w-4xl mx-auto">
                    <%= __('hero.title_line1') %> <br> <%= __('hero.title_line2') %>
                </h1>
                
                <a href="#plans" class="group relative inline-flex items-center gap-2 overflow-hidden rounded-full bg-accent px-8 py-3 font-bold text-white transition-all hover:bg-red-700 hover:ring-4 hover:ring-red-200">
                    <span><%= __('hero.cta') %></span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-5 w-5 transition-transform group-hover:translate-x-1">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                </a>
            </div>
        </div>
    </div>

    <div id="quick-nav-placeholder" class="h-0"></div>

    <div id="quick-nav" class="bg-white border-b border-gray-100 shadow-sm z-40 transition-all duration-300 w-full">
