<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/png" href="/img/common/logo.svg">
<title><%= seo.title %></title>
<meta name="description" content="<%= seo.description %>">
<link rel="canonical" href="<%= seo.canonical %>">
<meta property="og:site_name" content="Kokoro Kimono Rental">
<meta property="og:title" content="<%= seo.title %>">
<meta property="og:description" content="<%= seo.description %>">
<meta property="og:type" content="<%= seo.type %>">
<meta property="og:url" content="<%= seo.canonical %>">
<meta property="og:image" content="<%= seo.image %>">
<meta property="og:locale" content="<%= ({ en: 'en_US', vi: 'vi_VN', jp: 'ja_JP', zh: 'zh_CN' })[locale] || 'en_US' %>">
<% if (seo.hrefLangs) { %>
  <% Object.entries(seo.hrefLangs).forEach(([lang, href]) => { %>
    <link rel="alternate" hreflang="<%= lang %>" href="<%= href %>">
  <% }) %>
<% } %>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= seo.title %>">
<meta name="twitter:description" content="<%= seo.description %>">
<meta name="twitter:image" content="<%= seo.image %>">
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          bgBase: "#fdfbf7",
          main: "#544A47",
          accent: "#BA2636",
          gold: "#C5A059",
          sub1: "#8D837F"
        },
        fontFamily: {
          serif: ["Georgia", "serif"]
        }
      }
    }
  };
</script>
<% if (typeof structuredData !== "undefined" && structuredData && structuredData.length) { %>
  <% structuredData.forEach((schema) => { %>
    <script type="application/ld+json"><%- jsonLd(schema) %></script>
  <% }) %>
<% } %>
