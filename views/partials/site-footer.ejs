<footer class="bg-[#2c2725] text-white/80 py-10 border-t-4 border-accent">
  <div class="max-w-7xl mx-auto px-5 grid gap-8 md:grid-cols-[1.2fr_1fr_1fr]">
    <div>
      <img src="/img/common/logo.svg" alt="Kokoro Kimono Rental Kyoto logo" class="h-16 mb-4 brightness-0 invert opacity-60" loading="lazy" decoding="async">
      <p class="text-sm leading-relaxed max-w-md">
        <%= seoText.footerDescription %>
      </p>
    </div>
    <div>
      <h2 class="text-white font-bold mb-3 text-base"><%= seoText.explore %></h2>
      <div class="grid gap-2 text-sm">
        <a href="/kimono-rental-kyoto" class="hover:text-white"><%= seoText.navRental %></a>
        <a href="/kimono-photoshoot-kyoto" class="hover:text-white"><%= seoText.navPhotoshoot %></a>
        <a href="/blog" class="hover:text-white"><%= seoText.navBlog %></a>
      </div>
    </div>
    <div>
      <h2 class="text-white font-bold mb-3 text-base"><%= seoText.booking %></h2>
      <div class="grid gap-2 text-sm">
        <a href="/booking-step1" class="hover:text-white"><%= seoText.bookKimono %></a>
        <a href="tel:08096310559" class="hover:text-white">080-9631-0559</a>
        <a href="https://www.instagram.com/kokoroo_kimono/" target="_blank" rel="noopener" class="hover:text-white">Instagram</a>
      </div>
    </div>
  </div>
  <p class="max-w-7xl mx-auto px-5 mt-8 text-xs text-white/40"><%= seoText.copyright %></p>
</footer>
